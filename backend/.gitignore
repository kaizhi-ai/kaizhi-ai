# Compiled binary (matches ./backend in this directory only)
/backend

# Runtime auth state
/auths/

# Runtime data directory when KAIZHI_DATA_DIR=./data
/data/

# Runtime CLIProxyAPI config (generated from default template at startup)
/config.yaml

# Go test artifacts
*.test
*.out
coverage.out

# Embedded frontend build output (populated by `pnpm build` in ../frontend)
/web/dist/*
!/web/dist/.gitkeep
